# Laravel API backend URL
# Must include /api/v1 prefix. Use full HTTPS URL in production.
# Local development: http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=https://codemafia.ng/api/v1

# Canonical site URL
NEXT_PUBLIC_SITE_URL=https://codemafia.ng

# Laravel API URL without /api/v1 suffix (used by some CORS or auth flows)
NEXT_PUBLIC_API_BASE=https://codemafia.ng

# CORS note:
# The frontend sends credentials: "include" on all fetch requests.
# The backend's config/cors.php MUST use explicit origins (not '*')
# and supports_credentials MUST be true.
# If you change the frontend URL, update the origin whitelist in:
#   backend/config/cors.php
